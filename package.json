{
  "name": "@endeavour/vue-library",
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "tsc -p tsconfig.tests.json && vitest",
    "format": "prettier --write \"{src,tests}/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --list-different \"{src,tests}/**/*.{js,ts,vue,json,css,scss,md}\"",
    "prepare": "pnpm build && node -e \"try{require('husky').install()}catch(e){}\""
  },
  "dependencies": {
    "@vueuse/core": "14.2.1",
    "@vueuse/integrations": "14.2.1",
    "google-palette": "1.1.1",
    "lodash-es": "4.17.23",
    "sass": "1.99.0",
    "typescript-logging-log4ts-style": "2.2.0",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "1.0.3",
    "@pinia/testing": "1.0.3",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/d3": "7.4.3",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.5.2",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "6.0.2",
    "vite": "8.0.7",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6"
  },
  "peerDependencies": {
    "@primeuix/themes": "2.0.3",
    "pinia": "3.0.4",
    "primevue": "4.5.5",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces.js",
      "default": "./dist/interfaces.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "import": "./dist/enums.js",
      "default": "./dist/enums.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables.js",
      "default": "./dist/composables.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants.js",
      "default": "./dist/constants.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers.js",
      "default": "./dist/helpers.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models.js",
      "default": "./dist/models.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores.js",
      "default": "./dist/stores.js"
    }
  },
  "lint-staged": {
    "{src,tests}/**/*.{js,ts,vue,json,css,scss,md}": "prettier --write"
  },
  "publishConfig": {
    "registry": "https://artifactory.endhealth.co.uk/repository/npm/"
  }
}
